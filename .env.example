# ─────────────────────────────────────────────────────────────
# OCTO-8 environment template — copy to `.env.local` and fill in.
# `.env.local` is git-ignored; never commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Build-time only (never shipped to the browser) ──
# Used by `npm run fetch:images` to curate cinematic Unsplash imagery
# into src/data/gallery.ts. Not required for a normal build/deploy —
# the committed gallery.ts already contains public CDN URLs.
UNSPLASH_ACCESS_KEY=

# ── Server-side (Vercel serverless function `/api/assistant`) ──
# Point this at an Ollama instance the deployed site can reach
# (e.g. a private Render service). Leave empty to disable the proxy;
# the client then falls back to a direct local Ollama connection.
OLLAMA_URL=
OLLAMA_MODEL=gemma3:4b
